# Looker Instance & Embed Configuration
LOOKER_INSTANCE_URL=https://your-looker-instance.com
LOOKER_EMBED_DOMAIN=http://localhost:3000
VITE_LOOKER_INSTANCE_URL=https://your-looker-instance.com

# Looker Python SDK Credentials (read automatically by looker-sdk)
LOOKERSDK_BASE_URL=https://your-looker-instance.com
LOOKERSDK_CLIENT_ID=your_client_id
LOOKERSDK_CLIENT_SECRET=your_client_secret
LOOKERSDK_VERIFY_SSL=true
LOOKERSDK_TIMEOUT=120

# Frontend Embed Customizations
VITE_DASHBOARD_ID=1
VITE_THEME=Light_Mode
VITE_EXPLORE_PATH=thelook/orders
